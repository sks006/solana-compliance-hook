{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    // 🗲 Rule: Explicitly anchor the output directory layout to prevent structural shifting
    "outDir": "./dist",
    "rootDir": "./",
    
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "tests/**/*.ts",
    "target/types/**/*.ts"
  ]
}